<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Worshiplife Ministry Quiz</title>
    <style>
        /* YOUR CSS GOES HERE */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        /* Add your specific glassmorphism or aesthetic styles here */
        .card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
            width: 90%;
            max-width: 400px;
            margin-top: 50px;
            text-align: center;
        }
        button {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border: none;
            border-radius: 10px;
            background: #007bff;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div id="home-screen" class="card">
        <h1>Worshiplife Ministry</h1>
        <p id="sync-status">Connecting to Cloud...</p>
        <button onclick="startQuiz('old-testament')">Old Testament</button>
        <button onclick="startQuiz('new-testament')">New Testament</button>
        <button onclick="startQuiz('spiritual-growth')">Spiritual Growth</button>
        <button onclick="startQuiz('teen-life')">Teen Life</button>
    </div>

    <div id="quiz-screen" class="card" style="display:none;">
        <h2 id="question-text">Loading Question...</h2>
        <div id="options-container"></div>
    </div>

    <script>
        // YOUR WORKING JAVASCRIPT
        const SHEET_URL = "https://docs.google.com/spreadsheets/d/1RrgebuElaDoseB0t-wxl288SyN3PCjanxl8vw7Yxxq0/export?format=csv&cachebust=" + Date.now();
        
        let database = { "old": [], "new": [], "growth": [], "teens": [] };

        async function syncWithCloud() {
            try {
                const response = await fetch(SHEET_URL);
                const data = await response.text();
                parseCSV(data);
            } catch (e) {
                document.getElementById('sync-status').innerText = "Offline Mode Active";
            }
        }

        function parseCSV(text) {
            const rows = text.split('\n').slice(1);
            rows.forEach(row => {
                const columns = row.split('|'); 
                if (columns.length >= 4) {
                    const cat = columns[0].trim().toLowerCase();
                    const qData = {
                        question: columns[1].trim(),
                        options: columns[2].split(';').map(o => o.trim()),
                        answer: columns[3].trim()
                    };
                    if (cat.includes('teen')) database.teens.push(qData);
                    else if (database[cat]) database[cat].push(qData);
                }
            });
            document.getElementById('sync-status').innerText = "Ministry Cloud Synced";
        }

        function startQuiz(category) {
            const map = { 'old-testament': 'old', 'new-testament': 'new', 'spiritual-growth': 'growth', 'teen-life': 'teens' };
            const data = database[map[category]];
            if (!data || data.length === 0) {
                alert("This category is being updated!");
                return;
            }
            // Logic to show questions...
            document.getElementById('home-screen').style.display = 'none';
            document.getElementById('quiz-screen').style.display = 'block';
            document.getElementById('question-text').innerText = data[0].question;
        }

        syncWithCloud();
    </script>
</body>
</html>
